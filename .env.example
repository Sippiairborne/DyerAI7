# ===== LLM Configuration =====
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=sk-local
LLM_MODEL=your-custom-model
LLM_FAST_MODEL=your-custom-model-fast
LLM_CODE_MODEL=your-custom-model-code
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# ===== Database =====
DATABASE_URL=postgresql+asyncpg://aieng:aieng@localhost:5432/ai_engineer
REDIS_URL=redis://localhost:6379/0

# ===== Vector Store =====
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=ai_engineer_memory
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ===== Graph Store =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# ===== Sandbox =====
E2B_API_KEY=your_e2b_key
MODAL_TOKEN_ID=your_modal_token
MODAL_TOKEN_SECRET=your_modal_secret
DOCKER_HOST=unix:///var/run/docker.sock
SANDBOX_TIMEOUT=600
SANDBOX_GPU=A100
SANDBOX_MEMORY_GB=64
SANDBOX_DISK_GB=500

# ===== Experiment Tracking =====
WANDB_API_KEY=your_wandb_key
WANDB_PROJECT=ai-engineer
MLFLOW_TRACKING_URI=http://localhost:5000

# ===== HuggingFace =====
HF_TOKEN=your_hf_token
HF_HOME=/data/hf

# ===== API Server =====
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=4
API_SECRET_KEY=change-me-to-a-random-secret
API_CORS_ORIGINS=["http://localhost:8501"]

# ===== UI =====
UI_PORT=8501
UI_API_URL=http://localhost:8080

# ===== Storage =====
WORKSPACE_DIR=/data/workspaces
ARTIFACTS_DIR=/data/artifacts
DATASETS_DIR=/data/datasets
MODELS_DIR=/data/models
LOGS_DIR=/data/logs

# ===== Self Improvement =====
ENABLE_SELF_IMPROVEMENT=true
FINE_TUNE_THRESHOLD=50
FINE_TUNE_BASE_MODEL=your-custom-model
